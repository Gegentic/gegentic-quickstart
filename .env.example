# Copy to .env and fill in the values below. Everything with a placeholder
# default (postgres URLs, service hostnames) is already wired up correctly
# for the docker-compose network in docker-compose.yml -- don't change those
# unless you know what you're doing.

# ── Required: self-hosting license ──────────────────────────────────────────
# gegentic/api runs in self-hosted mode and requires a license key. Register
# at https://gegentic.ai to receive one by email, then paste it here.
LICENSE_KEY=

# ── Required: encryption keys for api ───────────────────────────────────────
# Must each be a 64-character hex string. The values below were freshly
# generated with `openssl rand -hex 32` for this template -- replace them
# with your own for anything beyond local experimentation (re-run that
# command, don't reuse these published ones for a real deployment).
ENCRYPT_KEY_FOR_API_KEY=56391a4be8dcc533d5af1b7720cd0775cfe5dcc774872462c567dc0682ada5f3
ENCRYPT_KEY_FOR_VIRTUAL_KEY=d3982444e1e1023e1cc97378a0fb28f3b04327e18e92daf6d7cc116ad907da71

# ── Required: at least one LLM credential for guardian's AI-based guardrails
# (jailbreak detection, compliance checks, LLM-judge criteria). Any
# OpenAI-compatible endpoint works.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# Bcrypt hash gateway uses for its internal auth header. Freshly generated for
# this template (bcrypt, cost 10) -- replace it for anything beyond local
# experimentation. $ is doubled ($$) because docker compose treats a single $
# as variable interpolation syntax; the container receives the real $2b$10$...
# value with $$ collapsed back to $ (verified directly against a throwaway
# container, not assumed).
INTERNAL_AUTH_HASHED_PASSWORD=$$2b$$10$$sZufykARrqR7tFmKoyCIfOIVXXCJ84mNNpBHDikat3V.9jAlCdLaS

SEED_ORG_NAME=My Organization

# No public gegentic image exists for obiguard-tracing-service yet, so traces
# have nowhere to land. Both api and guardian handle this gracefully (failed
# span exports are logged, not fatal) -- leave as-is unless you're running
# your own tracing backend.
TRACING_SERVICE_HOST=http://localhost:5001
