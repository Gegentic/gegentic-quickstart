# Copy to .env and fill in the values below. Everything with a placeholder
# default (postgres URLs, service hostnames) is already wired up correctly
# for the docker-compose network in docker-compose.yml -- don't change those
# unless you know what you're doing.

# ── Required: self-hosting license ──────────────────────────────────────────
# gegentic/api runs in self-hosted mode and requires a license key. Register
# at https://gegentic.ai to receive one by email, then paste it here.
LICENSE_KEY=

# Note: the RSA public key used to verify LICENSE_KEY is baked into the api
# image at build time and is intentionally not configurable here.

# ── Required: encryption keys for api ───────────────────────────────────────
# Must each be a 64-character hex string. The values below were freshly
# generated with `openssl rand -hex 32` for this template -- replace them
# with your own for anything beyond local experimentation (re-run that
# command, don't reuse these published ones for a real deployment).
ENCRYPT_KEY_FOR_API_KEY=56391a4be8dcc533d5af1b7720cd0775cfe5dcc774872462c567dc0682ada5f3
ENCRYPT_KEY_FOR_VIRTUAL_KEY=d3982444e1e1023e1cc97378a0fb28f3b04327e18e92daf6d7cc116ad907da71

# ── Required: at least one LLM credential for guardian's AI-based guardrails
# (jailbreak detection, compliance checks, LLM-judge criteria). Any
# OpenAI-compatible endpoint works.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# Internal auth shared between api and gateway: api sends
# LLM_GATEWAY_SERVICE_PASSWORD as a Bearer token on every call to gateway,
# gateway verifies it against the bcrypt hash in INTERNAL_AUTH_HASHED_PASSWORD.
# These two MUST be a matching plaintext/hash pair, or api's calls to gateway
# (e.g. listing AI providers) fail with 401s. Freshly generated for this
# template (bcrypt, cost 10) -- replace both together for anything beyond
# local experimentation, e.g.:
#   htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
# $ is doubled ($$) because docker compose treats a single $ as variable
# interpolation syntax; the container receives the real $2y$10$... value with
# $$ collapsed back to $ (verified directly against a throwaway container,
# not assumed).
LLM_GATEWAY_SERVICE_PASSWORD=local-dev-internal-secret
INTERNAL_AUTH_HASHED_PASSWORD=$$2y$$10$$x6LFi.viDSk6aWpzR3qfu.2tigtpm.T.XMhfIlB9dTM4YTfCKxnvW

# Comma-separated allowlist of emails permitted to create an account via
# email+password (e.g. for first-time admin access without email/Google set up).
# Leave blank to allow anyone to sign up.
GEGENTIC_ALLOWED_SIGNUP_EMAILS=admin@example.com
